HOST=localhost
PORT=3382
DB_STRING=SYSDBA:masterkey@127.0.0.1/sysdb?charset=utf8
JWT_SECRET=secret

# Vendor (SQL Account) API — only needed for write-wrapping endpoints like
# POST /payment-vouchers. Leave unset if you're not using those yet.
SQLACCOUNT_API_HOST=https://api.sql.my
SQLACCOUNT_API_ACCESS_KEY=
SQLACCOUNT_API_SECRET_KEY=
SQLACCOUNT_API_REGION=ap-southeast-5
SQLACCOUNT_API_SERVICE=sqlaccount
SQLACCOUNT_API_SESSION_TOKEN=